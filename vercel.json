{
  "version": 2,
  "builds": [
    {
      "src": "backend-server/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "client-side/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend-server/index.js"
    },
    {
      "src": "/auth/(.*)",
      "dest": "backend-server/index.js"
    },
    {
      "src": "/static/(.*)",
      "dest": "client-side/build/static/$1"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|ico|json|svg|map))",
      "dest": "client-side/build/$1"
    },
    {
      "src": "/(.*)",
      "dest": "client-side/build/index.html"
    }
  ]
}
